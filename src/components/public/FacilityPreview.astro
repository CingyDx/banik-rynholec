---
import { ArrowRight, Dumbbell, Flame, House, MapPin, Trophy } from "lucide-react";

import { facilities } from "../../content/site";

const icons = {
  football: Trophy,
  multifunction: MapPin,
  gym: Dumbbell,
  sauna: Flame,
  clubhouse: House,
};
---

<section class="facility-section section-surface">
  <div class="container facility-lead">
    <div class="facility-copy">
      <h2 class="section-title">Sportovní areál</h2>
      <div class="section-rule"></div>
      <p class="section-copy">
        Hřiště, zázemí, posilovna, sauna a klubovna v jednom přehledu pro návštěvníky i správce areálu.
      </p>
      <a class="command" href="/areal">Prohlédnout areál <ArrowRight aria-hidden="true" size={18} /></a>
    </div>

    <div class="facility-collage" aria-label="Fotky sportovního areálu">
      <figure class="collage-main media-frame">
        <img
          src="/images/placeholders/football-2.svg?v=2"
          alt="Sportovní areál TJ Baník Rynholec"
          width="450"
          height="253"
          loading="lazy"
        />
      </figure>
      <figure class="collage-side media-frame">
        <img src="/images/placeholders/sauna-2.svg?v=2" alt="" width="450" height="253" loading="lazy" />
      </figure>
      <figure class="collage-side media-frame">
        <img src="/images/placeholders/clubhouse-2.svg?v=2" alt="" width="450" height="253" loading="lazy" />
      </figure>
    </div>
  </div>

  <div class="container facility-list">
    {facilities.map((facility) => {
      const Icon = icons[facility.id];
      return (
        <a class="facility-item" href={`/areal#${facility.id}`}>
          <Icon aria-hidden="true" size={27} strokeWidth={1.8} />
          <span>{facility.bookingLabel}</span>
          <h3>{facility.name}</h3>
          <p>{facility.description}</p>
          <ArrowRight aria-hidden="true" size={18} />
        </a>
      );
    })}
  </div>
</section>

<style>
  .facility-section {
    padding-block: var(--space-8);
    background:
      linear-gradient(180deg, #0b0f0b 0%, #070907 100%);
    color: var(--color-white);
  }

  .facility-section .section-copy {
    color: #c4ccc6;
  }

  .facility-lead {
    display: grid;
    grid-template-columns: minmax(260px, 0.56fr) minmax(0, 1fr);
    gap: 3.5rem;
    align-items: center;
  }

  .facility-copy .command {
    margin-top: 2rem;
    color: var(--color-white);
  }

  .facility-collage {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(160px, 0.65fr);
    grid-template-rows: repeat(2, minmax(160px, 1fr));
    gap: 1rem;
    min-height: 470px;
  }

  .facility-collage figure {
    margin: 0;
  }

  .collage-main {
    grid-row: 1 / span 2;
  }

  .facility-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0;
    margin-top: 3.5rem;
    border-top: 1px solid #283029;
    border-left: 1px solid #283029;
  }

  .facility-item {
    display: grid;
    min-height: 250px;
    align-content: start;
    gap: 0.75rem;
    padding: 1.5rem;
    border-right: 1px solid #283029;
    border-bottom: 1px solid #283029;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 4%), rgb(255 255 255 / 1%)),
      #0f140f;
    transition:
      background var(--transition-fast),
      transform var(--transition-medium),
      box-shadow var(--transition-medium);
  }

  .facility-item:hover {
    background: #111811;
    box-shadow: 0 22px 60px rgb(0 0 0 / 24%);
    transform: translateY(-4px);
  }

  .facility-item > svg {
    color: var(--color-green-bright);
  }

  .facility-item span {
    color: var(--color-green-bright);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .facility-item h3 {
    margin: 0;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1.75rem;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .facility-item p {
    margin: 0 0 0.5rem;
    color: #b9c2bb;
    font-size: 0.9rem;
  }

  .facility-item > svg:last-child {
    margin-top: auto;
    transition: transform var(--transition-fast);
  }

  .facility-item:hover > svg:last-child {
    transform: translateX(5px);
  }

  @media (max-width: 1050px) {
    .facility-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .facility-section {
      padding-block: var(--space-6);
    }

    .facility-lead,
    .facility-collage {
      grid-template-columns: 1fr;
    }

    .facility-collage {
      min-height: 0;
      grid-template-rows: auto;
    }

    .collage-main {
      grid-row: auto;
      min-height: 290px;
    }

    .collage-side {
      min-height: 190px;
    }
  }

  @media (max-width: 560px) {
    .facility-list {
      grid-template-columns: 1fr;
    }

    .facility-item {
      min-height: 0;
    }
  }
</style>
