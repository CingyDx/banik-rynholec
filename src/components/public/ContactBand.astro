---
import { ArrowRight, MapPin } from "lucide-react";

import { club } from "../../content/site";
---

<section class="contact-band">
  <div class="container contact-layout">
    <div>
      <h2>Máte cestu do areálu?</h2>
      <p>Najděte adresu, mapu a kontaktní údaje na jednom místě.</p>
    </div>
    <div class="contact-actions">
      <a class="command command--primary" href="/kontakt">Kontakt <ArrowRight aria-hidden="true" size={18} /></a>
      <a
        class="command"
        href={`https://www.google.com/maps?q=${club.coordinates.latitude},${club.coordinates.longitude}`}
        target="_blank"
        rel="noreferrer"
      >
        Otevřít mapu <MapPin aria-hidden="true" size={18} />
      </a>
    </div>
  </div>
</section>

<style>
  .contact-band {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-5);
    background:
      linear-gradient(90deg, var(--color-green-deep), var(--color-green)),
      var(--color-green-deep);
    color: var(--color-white);
  }

  .contact-band::after {
    position: absolute;
    right: -4rem;
    bottom: -5rem;
    width: 240px;
    height: 260px;
    background: linear-gradient(90deg, transparent 0 28%, rgb(255 255 255 / 16%) 28% 48%, transparent 48% 58%, rgb(255 255 255 / 10%) 58% 78%, transparent 78%);
    content: "";
    transform: skewX(-30deg);
  }

  .contact-layout {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.8rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p {
    margin: 0.35rem 0 0;
  }

  .contact-actions {
    display: flex;
    gap: 0.75rem;
  }

  @media (max-width: 720px) {
    .contact-layout,
    .contact-actions {
      align-items: stretch;
      flex-direction: column;
    }

    h2 {
      font-size: 2.35rem;
    }
  }
</style>

