---
import { ArrowRight, MapPin } from "lucide-react";

import { club } from "../../content/site";
---

<section class="contact-band">
  <div class="container contact-layout">
    <div>
      <h2>Máte cestu do areálu?</h2>
      <p>{club.address}</p>
    </div>
    <div class="contact-actions">
      <a class="command command--primary" href="/kontakt">Kontakt <ArrowRight aria-hidden="true" size={18} /></a>
      <a
        class="command"
        href={`https://www.google.com/maps?q=${club.coordinates.latitude},${club.coordinates.longitude}`}
        target="_blank"
        rel="noreferrer"
      >
        Otevřít mapu <MapPin aria-hidden="true" size={18} />
      </a>
    </div>
  </div>
</section>

<style>
  .contact-band {
    padding-block: var(--space-5);
    background: var(--color-green-deep);
    color: var(--color-white);
  }

  .contact-layout {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.8rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p {
    margin: 0.35rem 0 0;
  }

  .contact-actions {
    display: flex;
    gap: 0.75rem;
  }

  @media (max-width: 720px) {
    .contact-layout,
    .contact-actions {
      align-items: stretch;
      flex-direction: column;
    }

    h2 {
      font-size: 2.35rem;
    }
  }
</style>

