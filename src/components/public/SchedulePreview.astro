---
import { ArrowRight, CalendarDays } from "lucide-react";

import { schedulePreview } from "../../content/site";
---

<section class="schedule-section" id="program">
  <div class="container">
    <div class="schedule-heading">
      <div>
        <h2 class="section-title">Nejbližší program</h2>
        <div class="section-rule"></div>
      </div>
      <a class="command" href="/kalendar">
        Celý kalendář
        <CalendarDays aria-hidden="true" size={19} />
      </a>
    </div>

    <div class="schedule-list">
      {schedulePreview.map((item) => (
        <a class="schedule-row" href="/kalendar">
          <span class="date-block">
            <strong>{item.day}</strong>
            <span>{item.date}</span>
          </span>
          <time>{item.time}</time>
          <span class="team">{item.team}</span>
          <span class="opponent">{item.opponent}<small>{item.venue}</small></span>
          <ArrowRight className="row-arrow" aria-hidden="true" size={22} />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .schedule-section {
    padding-block: var(--space-6);
    background: var(--color-white);
  }

  .schedule-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .schedule-list {
    border-top: 1px solid var(--color-line);
  }

  .schedule-row {
    display: grid;
    min-height: 92px;
    grid-template-columns: 100px 92px 150px 1fr 30px;
    align-items: center;
    border-bottom: 1px solid var(--color-line);
    transition: background var(--transition-fast);
  }

  .schedule-row:hover {
    background: var(--color-paper);
  }

  .date-block {
    display: grid;
    min-height: 64px;
    place-content: center;
    background: var(--color-green-deep);
    color: var(--color-white);
    line-height: 1.1;
    text-align: center;
  }

  .date-block strong {
    font-size: 0.8rem;
  }

  .date-block span {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
  }

  time,
  .team {
    padding-inline: 1rem;
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 600;
  }

  time {
    border-right: 3px solid var(--color-yellow);
  }

  .opponent {
    padding-inline: 1.5rem;
    font-weight: 600;
  }

  .opponent small {
    display: block;
    color: var(--color-muted);
    font-size: 0.8rem;
    font-weight: 400;
  }

  .row-arrow {
    color: var(--color-green);
    transition: transform var(--transition-fast);
  }

  .schedule-row:hover .row-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 820px) {
    .schedule-section {
      padding-block: var(--space-5);
    }

    .schedule-heading {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 1.5rem;
    }

    .schedule-heading .command {
      min-height: 44px;
    }

    .schedule-row {
      min-height: 104px;
      grid-template-columns: 74px 62px 1fr 24px;
    }

    .date-block {
      min-height: 72px;
    }

    time {
      padding-inline: 0.75rem;
      font-size: 1.2rem;
    }

    .team {
      align-self: end;
      padding: 0 0.75rem 0.1rem;
      font-size: 1.35rem;
    }

    .opponent {
      align-self: start;
      grid-column: 3;
      padding: 0.1rem 0.75rem 0;
      color: var(--color-muted);
      font-size: 0.78rem;
      font-weight: 400;
    }

    .opponent small {
      display: none;
    }

    .row-arrow {
      grid-column: 4;
      grid-row: 1;
    }
  }
</style>

