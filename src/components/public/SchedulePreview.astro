---
import { ArrowLeft, ArrowRight, CalendarDays, Clock, MapPin } from "lucide-react";
---

<section class="schedule-section section-surface" id="program">
  <div class="container schedule-layout" data-schedule-shell>
    <div class="schedule-heading">
      <div>
        <h2 class="section-title">Nejbližší program</h2>
        <div class="section-rule"></div>
        <p class="section-copy">
          Rychlý přehled zápasů, tréninků a bloků areálu. Detailní rozpis je připravený v kalendáři.
        </p>
      </div>
      <div class="schedule-actions">
        <a class="command" href="/kalendar">
          Celý kalendář
          <CalendarDays aria-hidden="true" size={19} />
        </a>
      </div>
    </div>

    <div class="schedule-carousel">
      <button type="button" class="carousel-float carousel-float-prev" data-schedule-prev aria-label="Předchozí akce v programu">
        <ArrowLeft aria-hidden="true" size={26} />
      </button>
      <button type="button" class="carousel-float-next" data-schedule-next aria-label="Další akce v programu">
        <ArrowRight aria-hidden="true" size={26} />
      </button>
      <div class="schedule-list" data-schedule-track aria-label="Nejbližší program TJ Baník Rynholec">
        <a class="schedule-card" href="/kalendar" aria-label="Kalendář bude doplněn">
          <span class="date-block">
            <strong>TJ</strong>
            <span>Brzy</span>
          </span>
          <span class="event-body">
            <span class="event-meta">
              <span><Clock aria-hidden="true" size={15} />Čeká na rozpis</span>
              <span><MapPin aria-hidden="true" size={15} />TJ Baník Rynholec</span>
            </span>
            <span class="event-type">Kalendář</span>
            <strong>Program bude doplněn</strong>
            <small>Po importu Excelu se tady zobrazí nejbližší akce</small>
          </span>
          <ArrowRight className="row-arrow" aria-hidden="true" size={22} />
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  type CalendarApiEvent = {
    end: string;
    resourceGroup: string;
    resourceLabel: string;
    start: string;
    status: string;
    title: string;
  };

  type DatedCalendarEvent = {
    event: CalendarApiEvent;
    start: Date;
  };

  document.querySelectorAll("[data-schedule-shell]").forEach((shell) => {
    const track = shell.querySelector("[data-schedule-track]");
    const prevButtons = shell.querySelectorAll("[data-schedule-prev]");
    const nextButtons = shell.querySelectorAll("[data-schedule-next]");

    if (!(track instanceof HTMLElement) || nextButtons.length === 0 || prevButtons.length === 0) {
      return;
    }

    const statusLabels: Record<string, string> = {
      volno: "Volno",
      obsazeno: "Obsazeno",
      trénink: "Trénink",
      zápas: "Zápas",
      "čeká na schválení": "Čeká na schválení",
    };
    const dayFormatter = new Intl.DateTimeFormat("cs-CZ", { weekday: "short" });
    const dateFormatter = new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "numeric" });
    const timeFormatter = new Intl.DateTimeFormat("cs-CZ", { hour: "2-digit", minute: "2-digit" });
    const cardTemplates = Array.from(track.querySelectorAll(".schedule-card")).map((card) => card.cloneNode(true));

    const getStep = () => {
      const card = track.querySelector(".schedule-card");
      if (!(card instanceof HTMLElement)) {
        return track.clientWidth;
      }

      const styles = window.getComputedStyle(track);
      const gap = Number.parseFloat(styles.columnGap || styles.gap || "16");
      return card.getBoundingClientRect().width + (Number.isFinite(gap) ? gap : 16);
    };

    const updateButtons = () => {
      const max = track.scrollWidth - track.clientWidth;
      prevButtons.forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = track.scrollLeft <= 4;
        }
      });
      nextButtons.forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = track.scrollLeft >= max - 4;
        }
      });
    };

    const createScheduleCard = (event: CalendarApiEvent, index: number) => {
      const start = new Date(event.start);
      const end = new Date(event.end);
      const template = cardTemplates[index % cardTemplates.length];
      const link = template instanceof HTMLAnchorElement ? (template.cloneNode(true) as HTMLAnchorElement) : document.createElement("a");
      link.classList.add("schedule-card");
      link.href = "/kalendar";
      link.setAttribute("aria-label", `${event.title}, ${event.resourceLabel}`);

      const day = link.querySelector(".date-block strong");
      const date = link.querySelector(".date-block span");
      const metaItems = link.querySelectorAll(".event-meta span");
      const eventType = link.querySelector(".event-type");
      const title = link.querySelector(".event-body > strong");
      const small = link.querySelector(".event-body small");

      if (day) day.textContent = dayFormatter.format(start);
      if (date) date.textContent = dateFormatter.format(start).replace(/\s/g, "");
      if (metaItems[0]) metaItems[0].textContent = timeFormatter.format(start) + "-" + timeFormatter.format(end);
      if (metaItems[1]) metaItems[1].textContent = event.resourceLabel;
      if (eventType) eventType.textContent = statusLabels[event.status] ?? event.status;
      if (title) title.textContent = event.title;
      if (small) small.textContent = `${event.resourceGroup} · ${statusLabels[event.status] ?? event.status}`;

      return link;
    };

    const createEmptyScheduleCard = () => {
      const template = cardTemplates[0];
      const link = template instanceof HTMLAnchorElement ? (template.cloneNode(true) as HTMLAnchorElement) : document.createElement("a");
      link.classList.add("schedule-card");
      link.href = "/kalendar";
      link.setAttribute("aria-label", "Kalendář bude doplněn");

      const day = link.querySelector(".date-block strong");
      const date = link.querySelector(".date-block span");
      const metaItems = link.querySelectorAll(".event-meta span");
      const eventType = link.querySelector(".event-type");
      const title = link.querySelector(".event-body > strong");
      const small = link.querySelector(".event-body small");

      if (day) day.textContent = "TJ";
      if (date) date.textContent = "Brzy";
      if (metaItems[0]) metaItems[0].textContent = "čeká na rozpis";
      if (metaItems[1]) metaItems[1].textContent = "TJ Baník Rynholec";
      if (eventType) eventType.textContent = "Kalendář";
      if (title) title.textContent = "Program bude doplněn";
      if (small) small.textContent = "Po importu Excelu se tady zobrazí nejbližší akce";

      return link;
    };

    const renderCalendarEvents = (events: CalendarApiEvent[]) => {
      const dated = events
        .map((event): DatedCalendarEvent => ({ event, start: new Date(event.start) }))
        .filter(({ start }: DatedCalendarEvent) => !Number.isNaN(start.getTime()))
        .sort((a: DatedCalendarEvent, b: DatedCalendarEvent) => a.start.getTime() - b.start.getTime());

      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const upcoming = dated.filter(({ start }: DatedCalendarEvent) => start.getTime() >= today.getTime());
      const selected = (upcoming.length > 0 ? upcoming : dated).slice(0, 12);
      if (selected.length === 0) {
        track.replaceChildren(createEmptyScheduleCard());
        track.scrollLeft = 0;
        updateButtons();
        return;
      }

      track.replaceChildren(...selected.map(({ event }, index) => createScheduleCard(event, index)));
      track.scrollLeft = 0;
      updateButtons();
    };

    const loadLiveSchedule = async () => {
      try {
        const response = await fetch("/api/calendar", { cache: "no-store", credentials: "same-origin" });
        if (!response.ok) {
          return;
        }
        const payload = await response.json();
        if (Array.isArray(payload.events)) {
          renderCalendarEvents(payload.events);
        }
      } catch {
        updateButtons();
      }
    };

    const refreshLiveSchedule = () => {
      void loadLiveSchedule();
    };

    prevButtons.forEach((button) => {
      button.addEventListener("click", () => {
        track.scrollBy({ left: -getStep(), behavior: "smooth" });
      });
    });

    nextButtons.forEach((button) => {
      button.addEventListener("click", () => {
        track.scrollBy({ left: getStep(), behavior: "smooth" });
      });
    });

    track.addEventListener("scroll", updateButtons, { passive: true });
    window.addEventListener("resize", updateButtons);
    window.addEventListener("focus", refreshLiveSchedule);
    window.addEventListener("banik-calendar-updated", refreshLiveSchedule);
    window.addEventListener("storage", (event) => {
      if (event.key === "banik-calendar-updated") {
        refreshLiveSchedule();
      }
    });
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) {
        refreshLiveSchedule();
      }
    });
    document.addEventListener("astro:page-load", refreshLiveSchedule);
    updateButtons();
    void loadLiveSchedule();
  });
</script>

<style>
  .schedule-section {
    padding-block: clamp(2.8rem, 5vw, var(--space-7));
    background:
      radial-gradient(circle at 18% 0%, rgb(47 135 63 / 14%), transparent 28%),
      linear-gradient(180deg, #050705 0%, #0b0f0b 100%);
    color: var(--color-white);
  }

  .schedule-layout {
    display: grid;
    gap: 2.25rem;
  }

  .schedule-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
  }

  .schedule-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .schedule-heading .command {
    color: var(--color-white);
  }

  .schedule-heading .section-copy {
    color: #c4ccc6;
  }

  .schedule-carousel {
    position: relative;
    overflow: hidden;
  }

  .schedule-carousel::after {
    position: absolute;
    inset: 0 0 0 auto;
    width: min(10vw, 110px);
    background: linear-gradient(90deg, transparent, #0b0f0b);
    content: "";
    pointer-events: none;
  }

  .carousel-float,
  .carousel-float-next {
    position: absolute;
    z-index: 3;
    top: 50%;
    display: inline-grid;
    width: 3.6rem;
    height: 5.4rem;
    place-items: center;
    border: 1px solid rgb(73 172 85 / 55%);
    background: var(--color-green);
    color: var(--color-white);
    cursor: pointer;
    box-shadow: 0 20px 50px rgb(0 0 0 / 35%);
    transform: translateY(-50%);
    transition:
      background var(--transition-fast),
      transform var(--transition-fast),
      opacity var(--transition-fast);
  }

  .carousel-float {
    left: 0;
  }

  .carousel-float-next {
    right: 0;
  }

  .carousel-float:hover {
    background: var(--color-green-dark);
    transform: translateY(-50%) translateX(-4px);
  }

  .carousel-float-next:hover {
    background: var(--color-green-dark);
    transform: translateY(-50%) translateX(4px);
  }

  .carousel-float:disabled,
  .carousel-float-next:disabled {
    cursor: not-allowed;
    opacity: 0;
    pointer-events: none;
  }

  .schedule-list {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding: 0 0 0.8rem;
    scroll-behavior: smooth;
    scroll-padding-inline: 0;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .schedule-list::-webkit-scrollbar {
    display: none;
  }

  .schedule-card {
    position: relative;
    display: grid;
    flex: 0 0 clamp(270px, 22vw, 318px);
    min-height: 310px;
    grid-template-rows: auto 1fr auto;
    overflow: hidden;
    border: 1px solid #283029;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 4%), rgb(255 255 255 / 1%)),
      #0f140f;
    box-shadow: 0 22px 60px rgb(0 0 0 / 24%);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-medium),
      transform var(--transition-medium);
    scroll-snap-align: start;
  }

  .schedule-card::before {
    position: absolute;
    inset: 0 0 auto;
    height: 5px;
    background: var(--color-green);
    content: "";
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-medium);
  }

  .schedule-card:hover {
    border-color: rgb(73 172 85 / 45%);
    box-shadow: 0 28px 80px rgb(0 0 0 / 34%);
    transform: translateY(-6px);
  }

  .schedule-card:hover::before {
    transform: scaleX(1);
  }

  .date-block {
    display: flex;
    min-height: 86px;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem;
    border-bottom: 1px solid #283029;
    background: #050705;
    color: var(--color-white);
    line-height: 1;
  }

  .date-block strong,
  .event-type,
  .event-body small {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
  }

  .date-block strong {
    color: var(--color-green-bright);
    font-size: 1rem;
  }

  .date-block span {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
  }

  .event-body {
    display: grid;
    align-content: start;
    gap: 0.8rem;
    padding: 1.35rem 1.2rem;
  }

  .event-meta {
    display: grid;
    gap: 0.35rem;
    color: #aeb8b0;
    font-size: 0.82rem;
  }

  .event-meta span {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: 0.45rem;
  }

  .event-meta svg {
    flex: 0 0 auto;
    color: var(--color-green);
  }

  .event-type {
    color: var(--color-green-bright);
    font-size: 1.05rem;
    line-height: 1;
  }

  .event-body > strong {
    max-width: 14ch;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 0.94;
    text-transform: uppercase;
  }

  .event-body small {
    color: #aeb8b0;
    font-size: 0.82rem;
    line-height: 1.2;
  }

  .row-arrow {
    margin: 0 1.2rem 1.2rem auto;
    color: var(--color-green);
    transition: transform var(--transition-fast);
  }

  .schedule-card:hover .row-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 720px) {
    .schedule-section {
      padding-block: 2.25rem var(--space-6);
    }

    .schedule-heading {
      grid-template-columns: 1fr;
    }

    .schedule-actions {
      display: grid;
      grid-template-columns: 1fr;
      align-items: center;
      margin-bottom: 0;
    }

    .schedule-heading .command {
      justify-content: center;
      width: 100%;
    }

    .schedule-card {
      flex-basis: min(82vw, 340px);
      min-height: 0;
    }

    .event-body > strong {
      max-width: none;
    }
  }
</style>
