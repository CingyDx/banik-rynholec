---
import { ArrowRight, Medal, Shirt, Trophy, Users } from "lucide-react";

import { teams } from "../../content/site";

const icons = {
  pripravka: Shirt,
  zaci: Users,
  "a-tym": Trophy,
  "stara-garda": Medal,
};
---

<section class="team-section">
  <div class="container team-layout">
    <div class="team-heading">
      <h2 class="section-title">Naše týmy</h2>
      <div class="section-rule"></div>
      <a class="text-link" href="/tymy">Všechny týmy <ArrowRight aria-hidden="true" size={18} /></a>
    </div>
    <div class="team-list">
      {teams.map((team) => {
        const Icon = icons[team.id];
        return (
          <a class="team-item" href={`/tymy#${team.id}`}>
            <Icon aria-hidden="true" size={38} strokeWidth={1.7} />
            <h3>{team.name}</h3>
            <p>{team.description}</p>
            <span>{team.ageGroup} · {team.focus}</span>
            <ArrowRight className="team-arrow" aria-hidden="true" size={20} />
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding-block: var(--space-7);
    background: var(--color-black);
    color: var(--color-white);
  }

  .team-layout {
    display: grid;
    grid-template-columns: 210px 1fr;
    gap: 3rem;
  }

  .team-heading .text-link {
    margin-top: 2rem;
    color: var(--color-green-bright);
  }

  .team-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .team-item {
    display: flex;
    min-height: 240px;
    align-items: flex-start;
    flex-direction: column;
    padding: 0.5rem 1.5rem;
    border-left: 1px solid #4a504b;
  }

  .team-item > svg:first-child,
  .team-arrow {
    color: var(--color-green-bright);
  }

  .team-item h3 {
    margin: 1.25rem 0 0.6rem;
    color: var(--color-green-bright);
    font-family: var(--font-display);
    font-size: 1.55rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .team-item p {
    margin: 0 0 0.85rem;
    color: #d2d7d3;
    font-size: 0.9rem;
  }

  .team-item span {
    margin-bottom: 1rem;
    color: #aeb8b0;
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .team-arrow {
    margin-top: auto;
    transition: transform var(--transition-fast);
  }

  .team-item:hover .team-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 920px) {
    .team-layout {
      grid-template-columns: 1fr;
    }

    .team-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem 0;
    }
  }

  @media (max-width: 540px) {
    .team-list {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .team-item {
      min-height: 0;
      padding-block: 1.5rem;
      border-top: 1px solid #4a504b;
      border-left: 0;
    }
  }
</style>

