---
import { ArrowRight, Medal, Shirt, Trophy, Users } from "lucide-react";

import { teams } from "../../content/site";

const icons = {
  pripravka: Shirt,
  zaci: Users,
  "a-tym": Trophy,
  "stara-garda": Medal,
};

const teamImages = {
  pripravka: "/images/placeholders/multifunction-2.svg?v=2",
  zaci: "/images/placeholders/football-2.svg?v=2",
  "a-tym": "/images/placeholders/football-3.svg?v=2",
  "stara-garda": "/images/placeholders/clubhouse-3.svg?v=2",
};
---

<section class="team-section section-surface">
  <div class="container team-layout">
    <div class="team-heading">
      <h2 class="section-title">Naše týmy</h2>
      <div class="section-rule"></div>
      <p>
        Kategorie klubu na jednom místě s návazností na kalendář, aktuality a kontakty.
      </p>
      <a class="text-link" href="/tymy">Všechny týmy <ArrowRight aria-hidden="true" size={18} /></a>
    </div>
    <div class="team-list">
      {teams.map((team, index) => {
        const Icon = icons[team.id];
        return (
          <a class="team-item" href={`/tymy#${team.id}`}>
            <span class="team-photo media-frame">
              <img src={teamImages[team.id]} alt="" width="450" height="253" loading="lazy" />
              <span>{String(index + 1).padStart(2, "0")}</span>
            </span>
            <span class="team-content">
              <Icon aria-hidden="true" size={34} strokeWidth={1.8} />
              <h3>{team.name}</h3>
              <p>{team.description}</p>
              <small>{team.ageGroup} · {team.focus}</small>
            </span>
            <ArrowRight className="team-arrow" aria-hidden="true" size={20} />
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .team-section {
    padding-block: var(--space-8);
    background: var(--color-black);
    color: var(--color-white);
  }

  .team-section::before {
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgb(255 255 255 / 18%), transparent);
    content: "";
  }

  .team-layout {
    display: grid;
    grid-template-columns: minmax(220px, 0.36fr) minmax(0, 1fr);
    gap: 3.5rem;
    align-items: start;
  }

  .team-heading {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
  }

  .team-heading p {
    margin: 1.4rem 0 2rem;
    color: #cdd5ce;
  }

  .team-heading .text-link {
    color: var(--color-green-bright);
  }

  .team-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .team-item {
    position: relative;
    display: grid;
    min-height: 420px;
    grid-template-rows: 190px 1fr auto;
    overflow: hidden;
    border: 1px solid #30372f;
    background: #101410;
    box-shadow: 0 18px 50px rgb(0 0 0 / 24%);
    transition:
      border-color var(--transition-fast),
      transform var(--transition-medium),
      box-shadow var(--transition-medium);
  }

  .team-item:hover {
    border-color: var(--color-green);
    box-shadow: var(--shadow-dark);
    transform: translateY(-5px);
  }

  .team-photo {
    position: relative;
    display: block;
    min-height: 190px;
    border: 0;
  }

  .team-photo::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 25%, rgb(9 11 9 / 66%));
    content: "";
  }

  .team-photo span {
    position: absolute;
    z-index: 1;
    right: 1rem;
    bottom: 0.75rem;
    color: rgb(255 255 255 / 74%);
    font-family: var(--font-display);
    font-size: 3.8rem;
    font-weight: 700;
    line-height: 1;
  }

  .team-content {
    display: grid;
    align-content: start;
    gap: 0.85rem;
    padding: 1.25rem;
  }

  .team-content > svg,
  .team-arrow {
    color: var(--color-green-bright);
  }

  .team-item h3 {
    margin: 0;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 2.2rem;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .team-item p {
    margin: 0;
    color: #d4dad5;
    font-size: 0.92rem;
  }

  .team-item small {
    color: #aeb8b0;
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .team-arrow {
    margin: 0 1.25rem 1.25rem auto;
    transition: transform var(--transition-fast);
  }

  .team-item:hover .team-arrow {
    transform: translateX(5px);
  }

  @media (max-width: 980px) {
    .team-layout {
      grid-template-columns: 1fr;
    }

    .team-heading {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .team-section {
      padding-block: var(--space-6);
    }

    .team-list {
      grid-template-columns: 1fr;
    }

    .team-item {
      min-height: 0;
    }
  }
</style>
