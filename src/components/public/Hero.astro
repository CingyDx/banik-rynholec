---
import { ArrowRight } from "lucide-react";

import { club } from "../../content/site";
---

<section class="hero">
  <img
    class="hero-image"
    src="/images/sportovni-areal-hero.jpg"
    alt="Fotbalové hřiště v Rynholci"
    width="450"
    height="253"
    fetchpriority="high"
  />
  <div class="hero-content container">
    <h1>TJ Baník<br />Rynholec</h1>
    <p>{club.tagline}</p>
    <div class="hero-actions">
      <a class="command command--primary hero-command" href="/kalendar">
        Zobrazit kalendář
        <ArrowRight aria-hidden="true" size={22} strokeWidth={2} />
      </a>
      <a class="hero-secondary" href="/areal">Sportovní areál</a>
    </div>
    <nav class="hero-quick-links" aria-label="Rychlé odkazy">
      <a href="/klub">Klub</a>
      <a href="/tymy">Týmy</a>
      <a href="/novinky">Novinky</a>
    </nav>
  </div>
  <div class="hero-stripes" aria-hidden="true"><span></span><span></span></div>
</section>

<style>
  .hero {
    position: relative;
    height: clamp(560px, calc(100dvh - var(--header-height) - 180px), 640px);
    min-height: 560px;
    overflow: hidden;
    background: var(--color-black);
    color: var(--color-white);
    isolation: isolate;
  }

  .hero-image {
    position: absolute;
    z-index: -2;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(1.05) contrast(1.04);
    transform: scale(1.01);
    animation: hero-drift 18s var(--ease-premium) infinite alternate;
  }

  .hero::after {
    position: absolute;
    z-index: -1;
    inset: 0;
    background:
      linear-gradient(90deg, rgb(9 11 9 / 88%) 0%, rgb(9 11 9 / 54%) 42%, rgb(9 11 9 / 10%) 74%),
      radial-gradient(circle at 18% 46%, rgb(47 135 63 / 20%), transparent 28%),
      linear-gradient(0deg, rgb(9 11 9 / 76%) 0%, transparent 42%);
    content: "";
  }

  .hero-content {
    display: flex;
    height: 100%;
    min-height: 560px;
    align-items: flex-start;
    flex-direction: column;
    justify-content: center;
    padding-block: 3rem;
  }

  h1 {
    max-width: 700px;
    margin: 0;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: clamp(5.2rem, 8.8vw, 8rem);
    font-weight: 700;
    line-height: 0.76;
    text-shadow: 0 3px 28px rgb(0 0 0 / 70%);
    text-transform: uppercase;
    animation: hero-rise 700ms var(--transition-medium) both;
  }

  p {
    margin: 2rem 0 1.5rem;
    max-width: 560px;
    padding: 0;
    background: transparent;
    font-size: 1.3rem;
    font-weight: 500;
    animation: hero-rise 760ms var(--transition-medium) 80ms both;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    animation: hero-rise 800ms var(--transition-medium) 150ms both;
  }

  .hero-command {
    min-width: 260px;
    min-height: 58px;
    font-size: 1.35rem;
  }

  .hero-secondary {
    display: inline-flex;
    min-height: 58px;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.15rem;
    border-bottom: 2px solid var(--color-green-bright);
    color: #dce3de;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    transition:
      color var(--transition-fast),
      transform var(--transition-fast),
      border-color var(--transition-fast);
  }

  .hero-secondary:hover {
    border-color: var(--color-yellow);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  .hero-quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2rem;
    animation: hero-rise 820ms var(--transition-medium) 220ms both;
  }

  .hero-quick-links a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0.45rem 0.7rem;
    border: 1px solid rgb(255 255 255 / 18%);
    background: rgb(255 255 255 / 6%);
    color: #d7ddd8;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .hero-quick-links a:hover {
    background: rgb(73 172 85 / 20%);
    border-color: var(--color-green-bright);
    color: var(--color-white);
    transform: translateY(-2px);
  }

  .hero-stripes {
    position: absolute;
    right: -90px;
    bottom: -85px;
    display: flex;
    height: 290px;
    gap: 20px;
    transform: skewX(-38deg);
  }

  .hero-stripes span {
    width: 58px;
    background: var(--color-green);
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-drift {
    from {
      transform: scale(1.01) translate3d(0, 0, 0);
    }

    to {
      transform: scale(1.065) translate3d(-1.2%, -0.7%, 0);
    }
  }

  @media (max-width: 820px) {
    .hero {
      display: grid;
      height: auto;
      min-height: auto;
      grid-template-rows: 240px auto;
    }

    .hero-image {
      position: relative;
      z-index: auto;
      top: auto;
      grid-row: 1;
      height: 240px;
      object-position: center;
    }

    .hero-content {
      grid-row: 2;
      height: auto;
      min-height: 0;
      justify-content: flex-start;
      padding-block: 1.8rem 2.35rem;
      background: var(--color-black);
    }

    h1 {
      font-size: 4.1rem;
      line-height: 0.82;
      text-shadow: none;
    }

    p {
      margin-block: 1rem;
      padding: 0;
      background: transparent;
      font-size: 1.12rem;
    }

    .hero-actions {
      width: 100%;
      align-items: stretch;
      flex-direction: column;
      gap: 0.6rem;
    }

    .hero-command {
      width: 100%;
      min-height: 54px;
      font-size: 1.18rem;
    }

    .hero-secondary {
      min-height: 54px;
      border: 1px solid rgb(255 255 255 / 22%);
      font-size: 1.18rem;
    }

    .hero-quick-links {
      margin-top: 1rem;
    }

    .hero-stripes {
      right: -50px;
      bottom: -130px;
      height: 300px;
      opacity: 0.55;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: auto;
      grid-template-rows: 220px auto;
    }

    .hero-image {
      height: 220px;
    }

    .hero-content {
      min-height: 0;
    }

    h1 {
      font-size: 3.85rem;
    }
  }
</style>
