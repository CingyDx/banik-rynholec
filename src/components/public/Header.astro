---
import { ArrowRight, Menu, X } from "lucide-react";

import { navigation } from "../../content/site";

type Props = {
  currentPath: string;
};

const { currentPath } = Astro.props;
const isActive = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="TJ Baník Rynholec - domů">
      <img class="brand-logo" src="/images/club-logo.png" alt="" width="58" height="82" />
      <span class="brand-name">TJ Baník<br />Rynholec</span>
    </a>

    <nav class="primary-nav" aria-label="Hlavní navigace">
      {navigation.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
      ))}
    </nav>

    <a class="command command--primary header-booking" href="/kalendar">
      Kalendář areálu
      <ArrowRight aria-hidden="true" size={18} strokeWidth={2} />
    </a>

    <div class="mobile-menu">
      <button
        class="mobile-menu-toggle"
        type="button"
        aria-label="Otevřít navigaci"
        aria-expanded="false"
        aria-controls="mobile-navigation"
      >
        <Menu className="open-icon" aria-hidden="true" size={27} strokeWidth={2} />
        <X className="close-icon" aria-hidden="true" size={27} strokeWidth={2} />
      </button>
      <nav class="mobile-nav" id="mobile-navigation" aria-label="Mobilní navigace" hidden>
        {navigation.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
        <a class="command command--primary" href="/kalendar">Kalendář areálu</a>
      </nav>
    </div>
  </div>
</header>

<script>
  function initMobileMenus() {
    const menuButtons = document.querySelectorAll<HTMLButtonElement>(".mobile-menu-toggle");

    for (const button of menuButtons) {
      if (button.dataset.menuReady === "true") continue;
      button.dataset.menuReady = "true";

      const menuId = button.getAttribute("aria-controls");
      const menu = menuId ? document.getElementById(menuId) : null;
      if (!(menu instanceof HTMLElement)) continue;

      const setOpen = (open: boolean) => {
        button.setAttribute("aria-expanded", String(open));
        button.setAttribute("aria-label", open ? "Zavřít navigaci" : "Otevřít navigaci");
        menu.hidden = !open;
        document.documentElement.classList.toggle("mobile-nav-open", open);
      };

      button.addEventListener("click", () => setOpen(button.getAttribute("aria-expanded") !== "true"));
      menu.addEventListener("click", (event) => {
        const target = event.target;
        if (target instanceof Element && target.closest("a")) {
          setOpen(false);
        }
      });
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setOpen(false);
          button.focus();
        }
      });
    }
  }

  document.addEventListener("astro:page-load", initMobileMenus);
  initMobileMenus();
</script>
