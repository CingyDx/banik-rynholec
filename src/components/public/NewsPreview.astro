---
import { ArrowRight } from "lucide-react";

import { newsPreview } from "../../content/site";
---

<section class="news-section section-surface">
  <div class="container news-heading">
    <div>
      <h2 class="section-title">Z klubu</h2>
      <div class="section-rule"></div>
      <p class="section-copy">Aktuality, zápasové články a důležité zprávy z klubu budou mít vlastní přehlednou sekci.</p>
    </div>
    <a class="command" href="/novinky">Všechny novinky <ArrowRight aria-hidden="true" size={18} /></a>
  </div>

  <div class="container news-list">
    {newsPreview.slice(0, 3).map((item, index) => (
      <a class:list={["news-item", { "is-featured": index === 0 }]} href={item.href}>
        <span class="news-image media-frame">
          <img src={item.image} alt="" width="450" height="253" loading="lazy" />
        </span>
        <span class="news-meta">{item.date} · {item.category}</span>
        <h3>{item.title}</h3>
        <p>{item.summary}</p>
        <span class="news-link">Otevřít <ArrowRight aria-hidden="true" size={18} /></span>
      </a>
    ))}
  </div>
</section>

<style>
  .news-section {
    padding-block: var(--space-8);
    background:
      radial-gradient(circle at 82% 10%, rgb(47 135 63 / 12%), transparent 28%),
      #070907;
    color: var(--color-white);
  }

  .news-section .section-copy {
    color: #c4ccc6;
  }

  .news-heading .command {
    color: var(--color-white);
  }

  .news-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    margin-bottom: 2.5rem;
  }

  .news-list {
    display: grid;
    grid-template-columns: 1.2fr repeat(2, minmax(0, 0.9fr));
    gap: 1rem;
  }

  .news-item {
    display: grid;
    min-height: 430px;
    align-content: start;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid #283029;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 4%), rgb(255 255 255 / 1%)),
      #0f140f;
    box-shadow: 0 22px 60px rgb(0 0 0 / 24%);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-medium),
      transform var(--transition-medium);
  }

  .news-item:hover {
    border-color: rgb(73 172 85 / 45%);
    box-shadow: 0 28px 80px rgb(0 0 0 / 34%);
    transform: translateY(-5px);
  }

  .news-image {
    display: block;
    aspect-ratio: 16 / 10;
    border-color: #283029;
  }

  .is-featured .news-image {
    aspect-ratio: 16 / 8.8;
  }

  .news-meta {
    color: var(--color-green-bright);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .news-item h3 {
    margin: 0;
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 1.85rem;
    line-height: 0.98;
    text-transform: uppercase;
  }

  .is-featured h3 {
    font-size: 2.45rem;
  }

  .news-item p {
    margin: 0;
    color: #b9c2bb;
    font-size: 0.92rem;
  }

  .news-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: auto;
    color: var(--color-green-bright);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
  }

  .news-link svg {
    transition: transform var(--transition-fast);
  }

  .news-item:hover .news-link svg {
    transform: translateX(5px);
  }

  @media (max-width: 920px) {
    .news-list {
      grid-template-columns: 1fr;
    }

    .news-item {
      min-height: 0;
    }
  }

  @media (max-width: 720px) {
    .news-section {
      padding-block: var(--space-6);
    }

    .news-heading {
      grid-template-columns: 1fr;
    }

    .news-heading .command {
      width: 100%;
    }

    .is-featured h3 {
      font-size: 2rem;
    }
  }
</style>
