---
import Footer from "../components/public/Footer.astro";
import Header from "../components/public/Header.astro";
import "../styles/global.css";

type Props = {
  canonical?: string;
  title?: string;
  description?: string;
  image?: string;
  robots?: string;
};

const siteName = "TJ Baník Rynholec";
const defaultTitle = `${siteName} | Fotbalový klub a sportovní areál`;
const defaultDescription =
  "Oficiální web TJ Baník Rynholec. Fotbalový klub, sportovní areál v Rynholci, týmy, novinky, galerie a aktuální program areálu.";

const {
  canonical,
  title = defaultTitle,
  description = defaultDescription,
  image = "/images/sportovni-areal-hero.jpg",
  robots = "index,follow",
} = Astro.props;
const pageTitle = title === siteName || title === defaultTitle ? title : `${title} | ${siteName}`;
const siteUrl = Astro.site ?? new URL("https://banikrynholec.cz");
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl);
const icon512Url = new URL("/icon-512.png", siteUrl);
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://banikrynholec.cz/#website",
      name: siteName,
      alternateName: ["Baník Rynholec", "banikrynholec.cz"],
      url: "https://banikrynholec.cz/",
    },
    {
      "@type": "SportsOrganization",
      "@id": "https://banikrynholec.cz/#organization",
      name: siteName,
      alternateName: "Baník Rynholec",
      description: defaultDescription,
      url: "https://banikrynholec.cz/",
      logo: icon512Url.toString(),
      image: imageUrl.toString(),
      sport: "Football",
      address: {
        "@type": "PostalAddress",
        streetAddress: "U hřiště",
        addressLocality: "Rynholec",
        addressCountry: "CZ",
      },
    },
  ],
};
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#090b09" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="image_src" href={imageUrl.toString()} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-192.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={imageUrl.toString()} />
    <meta property="og:image:alt" content="Sportovní areál TJ Baník Rynholec" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl.toString()} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Přejít na obsah</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      const revealSelector = [
        ".page-hero .container > *",
        ".schedule-heading",
        ".schedule-card",
        ".team-heading",
        ".team-item",
        ".facility-copy",
        ".facility-collage",
        ".facility-item",
        ".news-heading",
        ".news-item",
        ".contact-layout > *",
        ".footer-main > *",
        ".club-intro > *",
        ".club-metrics article",
        ".system-grid article",
        ".next-content > *",
        ".team-page-item",
        ".note-inner > *",
        ".areal-intro > *",
        ".operations-strip article",
        ".areal-list article",
        ".gallery-grid figure",
        ".news-feature > *",
        ".news-page-item",
        ".editorial-inner > *",
        ".contact-page > *",
        ".contact-grid article",
      ].join(",");

      let revealObserver: IntersectionObserver | null = null;

      function initPageMotion() {
        document.documentElement.classList.add("has-motion-js");

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.querySelectorAll(revealSelector).forEach((target) => target.classList.add("is-visible"));
          return;
        }

        revealObserver?.disconnect();
        revealObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver?.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );

        const targets = Array.from(document.querySelectorAll(revealSelector));
        for (const [index, target] of targets.entries()) {
          if (!(target instanceof HTMLElement) || target.dataset.revealReady === "true") continue;
          target.dataset.revealReady = "true";
          target.style.setProperty("--reveal-delay", `${Math.min((index % 8) * 55, 330)}ms`);
          target.classList.add("reveal-ready");

          const rect = target.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            target.classList.add("is-visible");
            continue;
          }

          revealObserver.observe(target);
        }

        window.setTimeout(() => {
          document
            .querySelectorAll(".reveal-ready:not(.is-visible)")
            .forEach((target) => target.classList.add("is-visible"));
        }, 900);
      }

      function initHeaderState() {
        const header = document.querySelector(".site-header");
        if (!(header instanceof HTMLElement)) return;

        const update = () => {
          header.classList.toggle("is-scrolled", window.scrollY > 24);
        };

        update();
        window.removeEventListener("scroll", update);
        window.addEventListener("scroll", update, { passive: true });
      }

      initHeaderState();
      initPageMotion();
    </script>
  </body>
</html>

