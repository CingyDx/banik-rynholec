---
import Footer from "../components/public/Footer.astro";
import Header from "../components/public/Header.astro";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "TJ Baník Rynholec",
  description = "Fotbal, sport a areál pro celý Rynholec.",
} = Astro.props;
const pageTitle = title === "TJ Baník Rynholec" ? title : `${title} | TJ Baník Rynholec`;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090b09" />
    <link rel="icon" type="image/png" href="/images/club-logo.png" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Přejít na obsah</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      const revealSelector = [
        ".page-hero .container > *",
        ".schedule-heading",
        ".schedule-card",
        ".team-heading",
        ".team-item",
        ".facility-copy",
        ".facility-collage",
        ".facility-item",
        ".news-heading",
        ".news-item",
        ".contact-layout > *",
        ".footer-main > *",
        ".club-intro > *",
        ".club-metrics article",
        ".system-grid article",
        ".next-content > *",
        ".team-page-item",
        ".note-inner > *",
        ".areal-intro > *",
        ".operations-strip article",
        ".areal-list article",
        ".gallery-grid figure",
        ".news-feature > *",
        ".news-page-item",
        ".editorial-inner > *",
        ".contact-page > *",
        ".contact-grid article",
      ].join(",");

      let revealObserver: IntersectionObserver | null = null;

      function initPageMotion() {
        document.documentElement.classList.add("has-motion-js");

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          document.querySelectorAll(revealSelector).forEach((target) => target.classList.add("is-visible"));
          return;
        }

        revealObserver?.disconnect();
        revealObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver?.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );

        const targets = Array.from(document.querySelectorAll(revealSelector));
        for (const [index, target] of targets.entries()) {
          if (!(target instanceof HTMLElement) || target.dataset.revealReady === "true") continue;
          target.dataset.revealReady = "true";
          target.style.setProperty("--reveal-delay", `${Math.min((index % 8) * 55, 330)}ms`);
          target.classList.add("reveal-ready");

          const rect = target.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            target.classList.add("is-visible");
            continue;
          }

          revealObserver.observe(target);
        }

        window.setTimeout(() => {
          document
            .querySelectorAll(".reveal-ready:not(.is-visible)")
            .forEach((target) => target.classList.add("is-visible"));
        }, 900);
      }

      function initHeaderState() {
        const header = document.querySelector(".site-header");
        if (!(header instanceof HTMLElement)) return;

        const update = () => {
          header.classList.toggle("is-scrolled", window.scrollY > 24);
        };

        update();
        window.removeEventListener("scroll", update);
        window.addEventListener("scroll", update, { passive: true });
      }

      initHeaderState();
      initPageMotion();
    </script>
  </body>
</html>

