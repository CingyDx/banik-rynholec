---
import { ArrowRight, CalendarDays } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Obsazenost areálu" description="Informativní přehled obsazenosti areálu TJ Baník Rynholec.">
  <PageHero
    title="Obsazenost areálu"
    description="Pro první verzi webu je obsazenost vedená jako informativní kalendář bez online rezervačního formuláře."
  />

  <section class="content-band">
    <div class="container availability-page">
      <article>
        <CalendarDays aria-hidden="true" size={34} strokeWidth={1.8} />
        <h2>Vše najdete v kalendáři</h2>
        <p>
          Kalendář ukazuje zápasy, tréninky a obsazené bloky areálu. Nové zápisy spravuje klub přes jednoduchou
          administraci nebo importem z Excelu.
        </p>
        <a class="command command--primary" href="/kalendar">
          Otevřít kalendář <ArrowRight aria-hidden="true" size={18} />
        </a>
      </article>
      <aside>
        <strong>V první verzi není online rezervační formulář.</strong>
        <span>Je to záměrně jednodušší varianta podle aktuálního klubového rozpočtu.</span>
      </aside>
    </div>
  </section>
</PublicLayout>

<style>
  .availability-page {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.45fr);
    gap: 2rem;
    align-items: stretch;
  }

  article,
  aside {
    padding: 2rem;
    border: 1px solid var(--color-line);
    background: var(--color-white);
  }

  article svg {
    color: var(--color-green);
  }

  h2 {
    margin: 1rem 0;
    font-family: var(--font-display);
    font-size: 2.7rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p,
  aside span {
    color: var(--color-muted);
  }

  aside {
    display: grid;
    align-content: center;
    gap: 1rem;
    background: var(--color-black);
    color: var(--color-white);
  }

  aside strong {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    text-transform: uppercase;
  }

  aside span {
    color: #d2d7d3;
  }

  @media (max-width: 760px) {
    .availability-page {
      grid-template-columns: 1fr;
    }
  }
</style>
