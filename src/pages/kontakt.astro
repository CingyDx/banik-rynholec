---
import { MapPin } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import { club } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Kontakt" description="Kde najdete TJ Baník Rynholec a sportovní areál.">
  <PageHero title="Kontakt" description="Sportovní areál TJ Baník Rynholec v ulici U hřiště." />
  <section class="content-band">
    <div class="container contact-page">
      <div>
        <span class="contact-label">Adresa</span>
        <h2>{club.address}</h2>
        <p>GPS {club.coordinates.latitude}, {club.coordinates.longitude}</p>
        <a class="command command--primary" href={`https://www.google.com/maps?q=${club.coordinates.latitude},${club.coordinates.longitude}`} target="_blank" rel="noreferrer">
          Otevřít mapu <MapPin aria-hidden="true" size={18} />
        </a>
      </div>
      <div class="contact-confirmation">
        <span class="contact-label">Klubové kontakty</span>
        <h2>Ověřujeme správné osoby</h2>
        <p>Telefon a e-mail zveřejníme až po potvrzení Michalem a Rudlou, aby návštěvníci psali přímo správnému člověku.</p>
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .contact-page {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .contact-page > div {
    min-height: 320px;
    padding: 2.5rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .contact-label {
    color: var(--color-green);
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
  }

  h2 {
    margin: 1rem 0 0;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p {
    margin: 1rem 0 2rem;
    color: var(--color-muted);
  }

  @media (max-width: 700px) {
    .contact-page {
      grid-template-columns: 1fr;
    }

    .contact-page > div {
      min-height: 0;
      padding: 2rem 1.5rem;
    }
  }
</style>

