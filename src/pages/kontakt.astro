---
import { Mail, MapPin, Phone, ShieldCheck } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import { club } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Kontakt" description="Kontakty a mapa areálu TJ Baník Rynholec.">
  <PageHero title="Kontakt" description="Adresa, mapa a základní kontaktní údaje klubu." />

  <section class="content-band">
    <div class="container contact-page">
      <article class="map-card">
        <div class="map-image media-frame">
          <img src="/images/placeholders/football-3.svg?v=2" alt="Sportovní areál TJ Baník Rynholec" width="450" height="253" />
        </div>
        <div>
          <span class="contact-label">Adresa</span>
          <h2>{club.address}</h2>
          <p>Sportovní areál TJ Baník Rynholec najdete u hřiště v Rynholci.</p>
          <a class="command command--primary" href={`https://www.google.com/maps?q=${club.coordinates.latitude},${club.coordinates.longitude}`} target="_blank" rel="noreferrer">
            Otevřít mapu <MapPin aria-hidden="true" size={18} />
          </a>
        </div>
      </article>

      <div class="contact-grid">
        <article>
          <Phone aria-hidden="true" size={26} strokeWidth={1.8} />
          <span class="contact-label">Telefon</span>
          <h2>+420 777 123 456</h2>
          <p>Hlavní kontakt pro dotazy ke klubu, týmům a domluvě v areálu.</p>
        </article>
        <article>
          <Mail aria-hidden="true" size={26} strokeWidth={1.8} />
          <span class="contact-label">E-mail</span>
          <h2>info@banikrynholec.cz</h2>
          <p>E-mail pro zprávy klubu, fotky do galerie a podklady k aktualitám.</p>
        </article>
        <article class="wide">
          <ShieldCheck aria-hidden="true" size={26} strokeWidth={1.8} />
          <span class="contact-label">Správa areálu</span>
          <h2>Správce areálu</h2>
          <p>Provozní informace a obsazenost hřiště najdete v klubovém kalendáři.</p>
        </article>
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .contact-page {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 2.5rem;
    align-items: stretch;
  }

  .map-card {
    border: 1px solid var(--color-line);
    background: var(--color-white);
    box-shadow: 0 18px 50px rgb(9 11 9 / 7%);
  }

  .map-image {
    min-height: 360px;
    border: 0;
  }

  .map-card div:not(.map-image) {
    padding: 2rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .contact-grid article {
    min-height: 230px;
    padding: 1.5rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    background: var(--color-white);
  }

  .contact-grid .wide {
    grid-column: span 2;
  }

  .contact-grid svg {
    margin-bottom: 1rem;
    color: var(--color-green);
  }

  .contact-label {
    color: var(--color-green);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
  }

  h2 {
    margin: 1rem 0 0;
    overflow-wrap: anywhere;
    font-family: var(--font-display);
    font-size: 2.45rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p {
    margin: 1rem 0 2rem;
    color: var(--color-muted);
  }

  @media (max-width: 850px) {
    .contact-page,
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-grid .wide {
      grid-column: auto;
    }

    .map-image {
      min-height: 240px;
    }
  }
</style>
