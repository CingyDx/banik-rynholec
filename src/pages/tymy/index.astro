---
import { ArrowRight } from "lucide-react";

import PageHero from "../../components/public/PageHero.astro";
import { teams } from "../../content/site";
import PublicLayout from "../../layouts/PublicLayout.astro";
---

<PublicLayout title="Týmy" description="Týmy TJ Baník Rynholec od přípravky po starou gardu.">
  <PageHero title="Naše týmy" description="Čtyři generace, jeden znak a společná radost ze hry." />
  <section class="content-band">
    <div class="container team-page-list">
      {teams.map((team, index) => (
        <article class="team-page-item" id={team.id}>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <div>
            <h2>{team.name}</h2>
            <p>{team.description}</p>
          </div>
          <a class="text-link" href="/kontakt">Kontakt <ArrowRight aria-hidden="true" size={18} /></a>
        </article>
      ))}
    </div>
  </section>
</PublicLayout>

<style>
  .team-page-list {
    border-top: 1px solid var(--color-line);
  }

  .team-page-item {
    display: grid;
    min-height: 150px;
    grid-template-columns: 70px 1fr auto;
    align-items: center;
    gap: 2rem;
    border-bottom: 1px solid var(--color-line);
  }

  .team-page-item > span {
    color: var(--color-green);
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p {
    margin: 0.4rem 0 0;
    color: var(--color-muted);
  }

  @media (max-width: 620px) {
    .team-page-item {
      grid-template-columns: 45px 1fr;
      gap: 1rem;
      padding-block: 1.5rem;
    }

    .team-page-item .text-link {
      grid-column: 2;
    }
  }
</style>

