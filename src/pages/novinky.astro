---
import { ArrowRight } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import { newsPreview } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Novinky" description="Aktuality, články a odkazy na výsledky TJ Baník Rynholec.">
  <PageHero title="Z klubu" description="Místo pro články k zápasům, klubové zprávy a odkazy na tabulky." />

  <section class="content-band">
    <div class="container news-feature" id="novy-web">
      <div class="feature-image media-frame">
        <img src={newsPreview[0].image} alt="Sportovní areál TJ Baník Rynholec" width="450" height="253" />
      </div>
      <article>
        <span>{newsPreview[0].date} · {newsPreview[0].category}</span>
        <h2>{newsPreview[0].title}</h2>
        <p>{newsPreview[0].summary}</p>
        <a class="text-link" href="/kalendar">
          Zobrazit kalendář <ArrowRight aria-hidden="true" size={18} />
        </a>
      </article>
    </div>

    <div class="container news-page-list" aria-label="Další novinky">
      {newsPreview.slice(1).map((item) => (
        <article class="news-page-item">
          <div class="item-image media-frame">
            <img src={item.image} alt="" width="450" height="253" loading="lazy" />
          </div>
          <span>{item.date} · {item.category}</span>
          <h2>{item.title}</h2>
          <p>{item.summary}</p>
          <a class="text-link" href={item.href}>
            Otevřít sekci <ArrowRight aria-hidden="true" size={18} />
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="editorial-note">
    <div class="container editorial-inner">
      <h2>Aktuality jednoduše</h2>
      <p>Novinky mohou sloužit pro zápasové reporty, klubové zprávy, fotky z akcí a důležité odkazy pro fanoušky.</p>
    </div>
  </section>
</PublicLayout>

<style>
  .news-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    align-items: stretch;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .feature-image {
    min-height: 420px;
  }

  .news-feature article {
    align-self: center;
  }

  .news-feature span,
  .news-page-item span {
    color: var(--color-green);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
  }

  h2 {
    margin: 1rem 0;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 0.98;
    text-transform: uppercase;
  }

  p {
    color: var(--color-muted);
  }

  .news-page-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .news-page-item {
    display: grid;
    min-height: 440px;
    align-content: start;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--color-line);
    background: var(--color-white);
    box-shadow: 0 18px 50px rgb(9 11 9 / 7%);
  }

  .item-image {
    aspect-ratio: 16 / 9;
    border-color: var(--color-line);
  }

  .news-page-item h2,
  .news-page-item p {
    margin: 0;
  }

  .editorial-note {
    padding-block: var(--space-6);
    background: var(--color-black);
    color: var(--color-white);
  }

  .editorial-inner {
    display: grid;
    grid-template-columns: minmax(240px, 0.55fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }

  .editorial-inner h2 {
    margin: 0;
  }

  .editorial-inner p {
    margin: 0;
    color: #d2d7d3;
  }

  @media (max-width: 820px) {
    .news-feature,
    .news-page-list,
    .editorial-inner {
      grid-template-columns: 1fr;
    }

    .feature-image {
      min-height: 260px;
    }

    .news-page-item {
      min-height: 0;
    }
  }
</style>
