---
import PageHero from "../components/public/PageHero.astro";
import { newsPreview } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Novinky" description="Aktuální zprávy z TJ Baník Rynholec.">
  <PageHero title="Z klubu" description="Zápasy, týmy, areál a všechno důležité kolem Baníku." />
  <section class="content-band">
    <div class="container news-page-list">
      {newsPreview.map((item, index) => (
        <article class="news-page-item" id={index === 0 ? "novy-web" : undefined}>
          <span>{item.date} · {item.category}</span>
          <h2>{item.title}</h2>
          <p>
            {index === 0
              ? "Vzniká samostatný web klubu s kalendářem, přehledem týmů a sportovním areálem."
              : "Podrobnosti a klubový obsah doplníme společně s odpovědnými správci."}
          </p>
        </article>
      ))}
    </div>
  </section>
</PublicLayout>

<style>
  .news-page-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .news-page-item {
    min-height: 300px;
    padding: 2rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .news-page-item span {
    color: var(--color-green);
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
  }

  h2 {
    margin: 1rem 0;
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    text-transform: uppercase;
  }

  p {
    color: var(--color-muted);
  }

  @media (max-width: 760px) {
    .news-page-list {
      grid-template-columns: 1fr;
    }

    .news-page-item {
      min-height: 0;
    }
  }
</style>

