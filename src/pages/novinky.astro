---
import { ArrowRight } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import { newsPreview } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Novinky" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit.">
  <PageHero title="Z klubu" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit." />

  <section class="content-band">
    <div class="container news-feature" id="novy-web">
      <img src="/images/sportovni-areal-hero.jpg" alt="Sportovní areál TJ Baník Rynholec" width="450" height="253" />
      <article>
        <span>{newsPreview[0].date} · {newsPreview[0].category}</span>
        <h2>{newsPreview[0].title}</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere erat a ante venenatis dapibus
          posuere velit aliquet.
        </p>
        <a class="text-link" href="/rezervace">
          Zobrazit rezervační náhled <ArrowRight aria-hidden="true" size={18} />
        </a>
      </article>
    </div>

    <div class="container news-page-list" aria-label="Další ukázkové novinky">
      {newsPreview.slice(1).map((item) => (
        <article class="news-page-item">
          <img src={item.image} alt="" width="450" height="253" loading="lazy" />
          <span>{item.date} · {item.category}</span>
          <h2>{item.title}</h2>
          <p>{item.summary}</p>
          <a class="text-link" href={item.href}>
            Otevřít sekci <ArrowRight aria-hidden="true" size={18} />
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="editorial-note">
    <div class="container editorial-inner">
      <h2>Placeholder obsah, ne vymyšlené reporty</h2>
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere erat a ante venenatis dapibus.</p>
    </div>
  </section>
</PublicLayout>

<style>
  .news-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    align-items: stretch;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .news-feature img {
    width: 100%;
    min-height: 420px;
    object-fit: cover;
  }

  .news-feature article {
    align-self: center;
  }

  .news-feature span,
  .news-page-item span {
    color: var(--color-green);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
  }

  h2 {
    margin: 1rem 0;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 0.98;
    text-transform: uppercase;
  }

  p {
    color: var(--color-muted);
  }

  .news-page-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .news-page-item {
    min-height: 440px;
    padding: 1.5rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .news-page-item img {
    width: 100%;
    aspect-ratio: 16 / 9;
    margin-bottom: 1.25rem;
    object-fit: cover;
  }

  .editorial-note {
    padding-block: var(--space-6);
    background: var(--color-black);
    color: var(--color-white);
  }

  .editorial-inner {
    display: grid;
    grid-template-columns: minmax(240px, 0.55fr) minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }

  .editorial-inner h2 {
    margin: 0;
  }

  .editorial-inner p {
    margin: 0;
    color: #d2d7d3;
  }

  @media (max-width: 820px) {
    .news-feature,
    .news-page-list,
    .editorial-inner {
      grid-template-columns: 1fr;
    }

    .news-feature img {
      min-height: 260px;
    }

    .news-page-item {
      min-height: 0;
    }
  }
</style>
