---
import { ArrowRight, Dumbbell, Flame, House, MapPin, ShieldCheck, Trophy } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import { club, facilities } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";

const icons = {
  football: Trophy,
  multifunction: MapPin,
  gym: Dumbbell,
  sauna: Flame,
  clubhouse: House,
};
---

<PublicLayout title="Sportovní areál" description="Přehled sportovního areálu TJ Baník Rynholec.">
  <PageHero title="Sportovní areál" description="Hřiště, zázemí a další prostory klubu na jednom místě." />

  <section class="content-band">
    <div class="container areal-intro">
      <img src="/images/sportovni-areal-hero.jpg" alt="Fotbalové hřiště v areálu Rynholec" width="450" height="253" />
      <div>
        <h2>Areál pro sport i regeneraci</h2>
        <p>
          Sportovní areál slouží pro fotbalové zápasy, tréninky, klubové akce i doplňkové využití zázemí.
          Obsazenost hřiště a důležité bloky budou vidět v kalendáři.
        </p>
        <a class="text-link" href={`https://www.google.com/maps?q=${club.coordinates.latitude},${club.coordinates.longitude}`} target="_blank" rel="noreferrer">
          {club.address} <MapPin aria-hidden="true" size={18} />
        </a>
      </div>
    </div>

    <div class="container operations-strip" aria-label="Budoucí provoz areálu">
      <article>
        <ShieldCheck aria-hidden="true" size={25} strokeWidth={1.8} />
        <strong>Jasný přehled</strong>
        <span>Program a obsazenost areálu budou dostupné z jednoho kalendáře.</span>
      </article>
      <article>
        <MapPin aria-hidden="true" size={25} strokeWidth={1.8} />
        <strong>Jedno místo</strong>
        <span>Hřiště, sauna, posilovna i klubovna budou popsané na webu.</span>
      </article>
      <article>
        <ArrowRight aria-hidden="true" size={25} strokeWidth={1.8} />
        <strong>Excel správa</strong>
        <span>Rozpis půjde připravit offline a později nahrát do webu.</span>
      </article>
    </div>

    <div class="container areal-list">
      {facilities.map((facility) => {
        const Icon = icons[facility.id];
        return (
          <article id={facility.id}>
            <div class="facility-image">
              <img src={facility.image} alt="" width="450" height="253" loading="lazy" />
              <Icon aria-hidden="true" size={30} strokeWidth={1.8} />
            </div>
            <div class="facility-content">
              <span>{facility.bookingLabel}</span>
              <h2>{facility.name}</h2>
              <p>{facility.description}</p>
              <ul>
                {facility.details.map((detail) => <li>{detail}</li>)}
              </ul>
              <small>{facility.availability}</small>
              <a class="text-link" href="/kalendar">Obsazenost v kalendáři <ArrowRight aria-hidden="true" size={18} /></a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</PublicLayout>

<style>
  .areal-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.8fr);
    align-items: center;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .areal-intro img {
    width: 100%;
    min-height: 380px;
    object-fit: cover;
  }

  .areal-intro h2,
  .areal-list h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .areal-intro p,
  .areal-list p {
    color: var(--color-muted);
  }

  .operations-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-bottom: 3rem;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .operations-strip article {
    display: grid;
    gap: 0.4rem;
    min-height: 150px;
    padding: 1.5rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .operations-strip svg {
    color: var(--color-green);
  }

  .operations-strip strong {
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .operations-strip span {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .areal-list {
    display: grid;
    gap: 2rem;
  }

  .areal-list article {
    display: grid;
    grid-template-columns: minmax(240px, 0.62fr) minmax(0, 1fr);
    border: 1px solid var(--color-line);
  }

  .facility-image {
    position: relative;
    min-height: 320px;
    background: var(--color-black);
  }

  .facility-image img {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    opacity: 0.84;
  }

  .facility-image svg {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    color: var(--color-white);
  }

  .facility-content {
    padding: 2rem;
  }

  .facility-content > span {
    color: var(--color-green);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
  }

  .facility-content ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.25rem 0;
    padding: 0;
    list-style: none;
  }

  .facility-content li {
    padding: 0.4rem 0.65rem;
    border: 1px solid var(--color-line);
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .facility-content small {
    display: block;
    margin-bottom: 1.25rem;
    color: var(--color-muted);
  }

  @media (max-width: 820px) {
    .areal-intro,
    .operations-strip,
    .areal-list article {
      grid-template-columns: 1fr;
    }

    .areal-intro img,
    .facility-image,
    .facility-image img {
      min-height: 240px;
    }
  }
</style>
