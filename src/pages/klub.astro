---
import { CalendarDays, ShieldCheck, Users } from "lucide-react";

import PageHero from "../components/public/PageHero.astro";
import { facilities, teams } from "../content/site";
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout title="Klub" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit.">
  <PageHero title="Klub" description="Lorem ipsum dolor sit amet, consectetur adipiscing elit." />

  <section class="content-band">
    <div class="container club-intro">
      <div class="club-copy">
        <h2>TJ Baník Rynholec</h2>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere erat a ante venenatis dapibus
          posuere velit aliquet. Donec ullamcorper nulla non metus auctor fringilla.
        </p>
        <p>
          Curabitur blandit tempus porttitor. Maecenas faucibus mollis interdum. Praesent commodo cursus magna,
          vel scelerisque nisl consectetur et.
        </p>
      </div>
      <img src="/images/sportovni-areal-secondary.jpg" alt="Sportovní areál TJ Baník Rynholec" width="450" height="253" />
    </div>

    <div class="container club-metrics" aria-label="Přehled klubu">
      <article>
        <strong>{teams.length}</strong>
        <span>Lorem ipsum dolor</span>
      </article>
      <article>
        <strong>{facilities.length}</strong>
        <span>Consectetur elit</span>
      </article>
      <article>
        <strong>1</strong>
        <span>Integer posuere</span>
      </article>
    </div>
  </section>

  <section class="club-system">
    <div class="container system-grid">
      <article>
        <Users aria-hidden="true" size={30} strokeWidth={1.8} />
        <h2>Klubový obsah</h2>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer posuere erat a ante venenatis dapibus.</p>
      </article>
      <article>
        <CalendarDays aria-hidden="true" size={30} strokeWidth={1.8} />
        <h2>Program areálu</h2>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent commodo cursus magna vel scelerisque.</p>
      </article>
      <article>
        <ShieldCheck aria-hidden="true" size={30} strokeWidth={1.8} />
        <h2>Správa pod kontrolou</h2>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec ullamcorper nulla non metus auctor.</p>
      </article>
    </div>
  </section>

  <section class="content-band">
    <div class="container next-content">
      <h2>Co doplníme před ostrým spuštěním</h2>
      <ul>
        <li>Lorem ipsum dolor sit amet</li>
        <li>Consectetur adipiscing elit</li>
        <li>Integer posuere erat a ante</li>
        <li>Praesent commodo cursus magna</li>
      </ul>
    </div>
  </section>
</PublicLayout>

<style>
  .club-intro {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    align-items: stretch;
    gap: 3rem;
  }

  .club-copy {
    align-self: center;
  }

  .club-copy h2,
  .system-grid h2,
  .next-content h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 2.6rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .club-copy p,
  .system-grid p {
    color: var(--color-muted);
  }

  .club-intro img {
    width: 100%;
    min-height: 390px;
    object-fit: cover;
  }

  .club-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 3rem;
    border-top: 1px solid var(--color-line);
    border-left: 1px solid var(--color-line);
  }

  .club-metrics article {
    min-height: 150px;
    padding: 1.5rem;
    border-right: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .club-metrics strong {
    display: block;
    color: var(--color-green);
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 0.9;
  }

  .club-metrics span {
    display: block;
    margin-top: 0.75rem;
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .club-system {
    padding-block: var(--space-7);
    background: var(--color-black);
    color: var(--color-white);
  }

  .system-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid #3a403b;
    border-left: 1px solid #3a403b;
  }

  .system-grid article {
    min-height: 280px;
    padding: 2rem;
    border-right: 1px solid #3a403b;
    border-bottom: 1px solid #3a403b;
  }

  .system-grid svg {
    margin-bottom: 1.5rem;
    color: var(--color-green-bright);
  }

  .system-grid p {
    color: #d0d6d1;
  }

  .next-content {
    display: grid;
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1.3fr);
    gap: 3rem;
    align-items: start;
  }

  .next-content ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .next-content li {
    padding: 1rem 1.25rem;
    border-left: 5px solid var(--color-green);
    background: var(--color-paper);
    color: var(--color-muted);
    font-weight: 600;
  }

  @media (max-width: 840px) {
    .club-intro,
    .club-metrics,
    .system-grid,
    .next-content {
      grid-template-columns: 1fr;
    }

    .club-intro img {
      min-height: 260px;
    }

    .system-grid article {
      min-height: 0;
    }
  }
</style>
